{
  "manifest_version": 3,
  "name": "Chrome收藏夹查看器",
  "version": "1.0.0",
  "description": "快速查看您在Chrome中收藏的网页",
  "permissions": [
    "storage",
    "bookmarks"
  ],
  "action": {
    "default_popup": "popup/index.html",
    "default_title": "Chrome收藏夹查看器"
  },
  "background": {
    "service_worker": "src/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  }
}